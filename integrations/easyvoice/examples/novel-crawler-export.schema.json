{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyvoice.local/schemas/novel-crawler-export.schema.json",
  "title": "EasyVoice novel crawler export",
  "type": "object",
  "additionalProperties": false,
  "required": ["book", "chapters"],
  "properties": {
    "book": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title"],
      "properties": {
        "id": {"type": ["string", "integer"], "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "author": {"type": "string"}
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["number", "title", "content"],
        "properties": {
          "id": {"type": ["string", "integer"]},
          "number": {"type": "integer", "minimum": 1},
          "title": {"type": "string", "minLength": 1},
          "content": {"type": "string"}
        }
      }
    }
  }
}
